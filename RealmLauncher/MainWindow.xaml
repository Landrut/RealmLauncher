<Window x:Class="RealmLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="REALM RolePlay Launcher"
        Width="900"
        Height="600"
        MinWidth="900"
        MinHeight="600"
        MaxWidth="900"
        MaxHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        FontFamily="{DynamicResource AppFont}"
        Background="#0F172A">
    <Window.Resources>
        <FontFamily x:Key="AppFont">pack://application:,,,/Assets/Fonts/#TT Norms Pro</FontFamily>
        <SolidColorBrush x:Key="BgMain" Color="#0F172A"/>
        <SolidColorBrush x:Key="BottomStrip" Color="#020617"/>
        <SolidColorBrush x:Key="PanelBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="TextMain" Color="#DBE5F5"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="StrokeDark" Color="#020617"/>
        <SolidColorBrush x:Key="InputBg" Color="#111827"/>
        <SolidColorBrush x:Key="InputStroke" Color="#334155"/>

        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#F03B82F6"/>
            <Setter Property="BorderBrush" Value="#020617"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF4C8FFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextInputStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="29"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="RealmCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Mark"
                                    Width="15"
                                    Height="15"
                                    CornerRadius="5"
                                    Background="#D9D9D9"
                                    BorderBrush="#020617"
                                    BorderThickness="1"
                                    Margin="0,0,8,0">
                                <Path x:Name="Tick"
                                      Data="M2,8 L5.5,11.5 L13,4"
                                      Stroke="#DBE5F5"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Mark" Property="Background" Value="#F03B82F6"/>
                                <Setter TargetName="Mark" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="Tick" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Background" Value="#101A30"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgMain}">
        <Grid.RowDefinitions>
            <RowDefinition Height="78"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>

        <Path Data="M891.429 0H8.57143C3.83756 0 0 8.9543 0 20V580C0 591.046 3.83756 600 8.57143 600H891.429C896.162 600 900 591.046 900 580V20C900 8.9543 896.162 0 891.429 0Z"
              Stretch="Fill"
              Opacity="0.3">
            <Path.Fill>
                <LinearGradientBrush MappingMode="Absolute"
                                     StartPoint="80,-44"
                                     EndPoint="900,600">
                    <GradientStop Color="#EA020617" Offset="0"/>
                    <GradientStop Color="#BF1D75FA" Offset="0.475382"/>
                    <GradientStop Color="#C31A6BE4" Offset="0.526337"/>
                    <GradientStop Color="#EA020617" Offset="1"/>
                </LinearGradientBrush>
            </Path.Fill>
        </Path>

        <Border Grid.RowSpan="3" BorderThickness="1" BorderBrush="#4D1D75FA"/>
        <Rectangle Grid.Row="2" Fill="{StaticResource BottomStrip}"/>
        <Rectangle Grid.Row="0" Height="2" Fill="#B5020617" VerticalAlignment="Bottom" Margin="-15,0,-15,0"/>

        <Grid Grid.Row="0" Background="#0F172A" MouseLeftButtonDown="HeaderBar_OnMouseLeftButtonDown">
            <Image x:Name="imgLogo" Width="146" Height="50" Margin="20,15,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Button x:Name="btnOpenSettings"
                    Width="181"
                    Height="28"
                    Margin="0,25,70,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Content="Настройки"
                    Style="{StaticResource PillButtonStyle}"
                    Click="BtnOpenSettings_OnClick"/>
            <Button x:Name="btnCloseApp"
                    Width="28"
                    Height="28"
                    Margin="0,25,34,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Content="✕"
                    ToolTip="Закрыть"
                    Style="{StaticResource PillButtonStyle}"
                    Click="BtnCloseApp_OnClick"/>
        </Grid>

        <Grid x:Name="MainPage" Grid.Row="1" Margin="24,14,24,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="32" Background="#333B82F6" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Новости / Обновления"
                               Foreground="{StaticResource TextMain}"
                               FontSize="20"
                               FontWeight="Bold"
                               TextAlignment="Center"/>
                    <Rectangle Grid.Row="1" Height="2" Width="354" HorizontalAlignment="Center" Fill="#B5020617" Margin="0,10,0,12"/>
                    <TextBox x:Name="txtNews"
                             Grid.Row="2"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="12"
                             Background="#101A30"
                             Foreground="{StaticResource TextMain}"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Padding="8"
                             Text="Загрузка новостей..."/>
                </Grid>
            </Border>

            <Border Grid.Column="2" CornerRadius="32" Background="#333B82F6" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="URL JSON сервера" Foreground="{StaticResource TextMain}" FontSize="14"/>
                    <TextBox x:Name="txtConfigUrl" Grid.Row="1" Style="{StaticResource TextInputStyle}" Margin="0,6,0,10"/>

                    <TextBlock Grid.Row="2" Text="Пароль сервера" Foreground="{StaticResource TextMain}" FontSize="14"/>
                    <PasswordBox x:Name="txtServerPassword"
                                 Grid.Row="3"
                                 Height="29"
                                 Margin="0,6,0,10"
                                 Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 Foreground="{StaticResource TextMain}"
                                 Background="{StaticResource InputBg}"
                                 BorderBrush="{StaticResource InputStroke}"
                                 BorderThickness="1"/>

                    <TextBlock x:Name="lblSteamCmdStatus"
                               Grid.Row="4"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="13"
                               Text="SteamCMD: неизвестно"/>
                    <TextBlock x:Name="lblStatus"
                               Grid.Row="5"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource TextMain}"
                               FontSize="13"
                               Text="Готово."/>

                    <ProgressBar x:Name="progressMods"
                                 Grid.Row="7"
                                 Height="14"
                                 Margin="0,293,0,-65"
                                 Minimum="0"
                                 Maximum="1000"
                                 Value="0"
                                 Foreground="#3B82F6"
                                 Background="#263249"/>

                    <Grid Grid.Row="7">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Button x:Name="btnPlay"
                                Grid.Row="0"
                                Width="181"
                                HorizontalAlignment="Right"
                                Content="Играть"
                                Style="{StaticResource PillButtonStyle}"
                                Click="BtnPlay_OnClick"/>
                        <TextBox x:Name="txtLog"
                                 Grid.Row="2"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Background="#101A30"
                                 Foreground="#DBE5F5"
                                 BorderBrush="#334155"
                                 BorderThickness="1"
                                 FontSize="12"
                                 Padding="8"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="SettingsPage" Grid.Row="1" Visibility="Collapsed" Margin="24,14,24,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="32" Background="#333B82F6" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Путь к ConanSandbox.exe" Foreground="{StaticResource TextMain}" FontSize="14"/>
                    <TextBox x:Name="txtConanExe"
                             Grid.Row="1"
                             Style="{StaticResource TextInputStyle}"
                             Margin="0,6,0,10"/>
                    <Button x:Name="btnBrowseConanExe"
                            Grid.Row="2"
                            Height="27"
                            Content="Обзор..."
                            Style="{StaticResource PillButtonStyle}"
                            Background="#F0284F8E"
                            Click="BtnBrowseConanExe_OnClick"/>
                    <Button x:Name="btnCheckSteamCmd"
                            Grid.Row="3"
                            Height="27"
                            Margin="0,12,0,0"
                            Content="Проверить / Установить SteamCMD"
                            Style="{StaticResource PillButtonStyle}"
                            Click="BtnCheckSteamCmd_OnClick"/>
                    <Button x:Name="btnCheckUpdates"
                            Grid.Row="4"
                            Height="27"
                            Margin="0,12,0,0"
                            Content="Проверить обновление лаунчера"
                            Style="{StaticResource PillButtonStyle}"
                            Click="BtnCheckUpdates_OnClick"/>
                    <TextBlock Grid.Row="5"
                               Margin="0,14,0,0"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               Text="Параметры сервера на главной странице."/>
                </Grid>
            </Border>

            <Border Grid.Column="2" CornerRadius="32" Background="#333B82F6" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Параметры игры" Foreground="{StaticResource TextMain}" FontSize="20" FontWeight="Bold"/>
                    <Rectangle Grid.Row="1" Height="2" Width="223" HorizontalAlignment="Left" Fill="#B5020617" Margin="0,10,0,12"/>
                    <StackPanel Grid.Row="2" Margin="0,0,0,12">
                        <CheckBox x:Name="chkDisableIntro"
                                  Style="{StaticResource RealmCheckBoxStyle}"
                                  Content="Отключить вступительный ролик"
                                  ToolTip="Заменяет вступительный ролик Conan Exiles на чёрный экран во время загрузки игры."/>
                        <CheckBox x:Name="chkAutoSubscribe"
                                  Style="{StaticResource RealmCheckBoxStyle}"
                                  IsChecked="True"
                                  Content="Автоподписка на моды Workshop"
                                  ToolTip="Открывает страницы недостающих модов в Steam Workshop, чтобы подписаться быстрее."/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Button x:Name="btnBackToMain"
                    Width="181"
                    Height="28"
                    Margin="0,13,34,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Content="Назад"
                    Style="{StaticResource PillButtonStyle}"
                    Visibility="Collapsed"
                    Click="BtnBackToMain_OnClick"/>
        </Grid>
    </Grid>
</Window>
