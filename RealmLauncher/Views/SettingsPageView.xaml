<UserControl x:Class="RealmLauncher.Views.SettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1040"
             d:DesignHeight="548"
             Background="Transparent">
    <Grid Margin="24,14,24,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Настройки"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#E5F0FF"
                       HorizontalAlignment="Center"/>

            <Border Grid.Row="1"
                    Margin="4,10,4,0"
                    CornerRadius="28"
                    Background="{DynamicResource PanelFill}"
                    BorderBrush="#5E7DB5"
                    BorderThickness="1.2">
                <Grid Margin="24,20,24,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="64"/>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="58"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="1"
                               Text="Проверка Steam"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextMain}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top" Height="21" Width="128"/>
                    <Button x:Name="btnCheckSteamCmd" x:FieldModifier="public"
                            Grid.Row="1"
                            Width="230"
                            Content="Проверить / Запустить"
                            Style="{DynamicResource PillButtonStyle}"
                            HorizontalAlignment="Center" Margin="0,26,0,24"/>

                    <TextBlock Grid.Row="2"
                               Text="Путь к ConanSandbox.exe"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextMain}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top" Height="22" Width="198"/>

                    <TextBox x:Name="txtConanExe" x:FieldModifier="public"
                             Grid.Row="5"
                             Visibility="Collapsed"
                             Style="{DynamicResource TextInputStyle}" Margin="0,0,0,48" Grid.RowSpan="2"/>

                    <Button x:Name="btnBrowseConanExe" x:FieldModifier="public"
                            Grid.Row="2"
                            Width="230"
                            Content="Обзор"
                            Style="{DynamicResource PillButtonStyle}"
                            HorizontalAlignment="Center" Margin="0,27,0,23"/>

                    <TextBlock Grid.Row="3"
                               Text="Обновление лаунчера"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextMain}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" Height="22" Width="175"/>

                    <Button x:Name="btnCheckUpdates" x:FieldModifier="public"
                            Grid.Row="5"
                            Width="230"
                            Content="Проверить обновление"
                            Style="{DynamicResource PillButtonStyle}"
                            HorizontalAlignment="Center" Margin="0,0,0,50" Grid.RowSpan="2"/>
                </Grid>
            </Border>
            <Rectangle Grid.Row="0" Height="2.5" Fill="#6DB2FF" Margin="58,48,58,474" Opacity="0.8" Grid.RowSpan="2"/>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Rectangle Grid.Row="0" Height="2.5" Fill="#6DB2FF" Margin="58,40,58,0" Opacity="0.8"/>
            <Border Grid.Row="1"
                    CornerRadius="28"
                    Background="{DynamicResource PanelFill}"
                    BorderBrush="#5E7DB5"
                    BorderThickness="1.2">
                <StackPanel Margin="48,28,48,0">
                    <CheckBox x:Name="chkDisableIntro" x:FieldModifier="public"
                              Margin="0,0,0,14"
                              Style="{DynamicResource RealmCheckBoxStyle}"
                              Content="Отключить вступительный ролик"
                              ToolTip="Заменяет вступительный ролик Conan Exiles на черный экран при загрузке игры."/>

                    <CheckBox x:Name="chkAutoSubscribe" x:FieldModifier="public"
                              Style="{DynamicResource RealmCheckBoxStyle}"
                              IsChecked="True"
                              Content="Авто-подписка на моды Workshop"
                              ToolTip="Автоматически подписывает аккаунт Steam на моды из списка сервера перед запуском."/>
                </StackPanel>
            </Border>
            <TextBlock Grid.Row="0"
                FontSize="32"
                FontWeight="Bold"
                Foreground="#E5F0FF"
                HorizontalAlignment="Center" Margin="0,0,0,10"><Run Text="Дополнительн"/><Run Language="ru-ru" Text="о"/></TextBlock>
        </Grid>
    </Grid>
</UserControl>
