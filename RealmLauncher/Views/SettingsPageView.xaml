<UserControl x:Class="RealmLauncher.Views.SettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="900"
             Height="468"
             d:DesignWidth="900"
             d:DesignHeight="600"
             Background="Transparent">
	<Grid>
		<Grid Visibility="Collapsed" d:Visibility="Visible" IsHitTestVisible="False">
			<Grid.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="#132D5F" Offset="0"/>
					<GradientStop Color="#102750" Offset="1"/>
				</LinearGradientBrush>
			</Grid.Background>
			<Rectangle Height="78" VerticalAlignment="Top" Fill="#16356B"/>
			<Rectangle Height="2" VerticalAlignment="Top" Margin="0,76,0,0" Fill="#031531"/>
			<Rectangle Height="54" VerticalAlignment="Bottom" Fill="#010C2A"/>
			<TextBlock Text="REALM" Foreground="#F7B74D" FontSize="46" FontWeight="Bold" Margin="20,8,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
			<Button Content="Главное меню" Width="180" Height="30" Margin="0,16,58,0" HorizontalAlignment="Right" VerticalAlignment="Top"/>
		</Grid>

		<Canvas d:Margin="0,78,0,54">
			<TextBlock Canvas.Left="184" Text="Настройки" Foreground="{DynamicResource TextMain}" FontSize="18" FontWeight="Bold" Canvas.Top="33" HorizontalAlignment="Left" VerticalAlignment="Top"/>

			<Border Canvas.Left="56" Canvas.Top="62" Width="360" Height="320" CornerRadius="45" Background="{DynamicResource PanelFill}"/>
			<Border Canvas.Left="479" Canvas.Top="62" Width="360" Height="320" CornerRadius="45" Background="{DynamicResource PanelFill}" HorizontalAlignment="Left" VerticalAlignment="Center"/>

			<TextBlock Canvas.Left="116" Canvas.Top="103" Width="230" Text="Проверка Steam" TextAlignment="Center" Foreground="{DynamicResource TextMain}" FontSize="14" FontWeight="SemiBold"/>
			<Rectangle Canvas.Left="106" Canvas.Top="124" Width="252" Height="3" Fill="#031531"/>
			<Button x:Name="btnCheckSteamCmd" x:FieldModifier="public"
                    Canvas.Left="128" Canvas.Top="141" Width="205" Height="32"
                    Content="Проверить / Запустить" Style="{DynamicResource PillButtonStyle}"/>

			<TextBlock Canvas.Left="106" Canvas.Top="178" Width="252" Text="Путь к ConanSandbox.exe" TextAlignment="Center" Foreground="{DynamicResource TextMain}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Top"/>
			<Rectangle Canvas.Left="106" Canvas.Top="202" Width="252" Height="3" Fill="#031531" HorizontalAlignment="Center" VerticalAlignment="Top"/>
			<TextBox x:Name="txtConanExe" x:FieldModifier="public"
                     Canvas.Left="106" Canvas.Top="234" Width="252" Style="{DynamicResource TextInputStyle}" Visibility="Collapsed"/>
			<Button x:Name="btnBrowseConanExe" x:FieldModifier="public"
                    Canvas.Left="128" Canvas.Top="213" Width="206" Height="32"
                    Content="Обзор" Style="{DynamicResource PillButtonStyle}" HorizontalAlignment="Center" VerticalAlignment="Top"/>

			<TextBlock Canvas.Left="106" Canvas.Top="250" Width="252" Text="Обновление лаунчера" TextAlignment="Center" Foreground="{DynamicResource TextMain}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Top"/>
			<Rectangle Canvas.Left="106" Canvas.Top="274" Width="252" Height="3" Fill="#031531" HorizontalAlignment="Left" VerticalAlignment="Center"/>
			<Button x:Name="btnCheckUpdates" x:FieldModifier="public"
                    Canvas.Left="128" Canvas.Top="282" Width="205" Height="32"
                    Content="Проверить обновление" Style="{DynamicResource PillButtonStyle}" HorizontalAlignment="Center" VerticalAlignment="Top"/>

			<CheckBox x:Name="chkDisableIntro" x:FieldModifier="public"
                      Canvas.Left="547" Canvas.Top="103"
                      Style="{DynamicResource RealmCheckBoxStyle}"
                      Content="Отключить вступительный ролик"
                      ToolTip="Заменяет вступительный ролик Conan Exiles на черный экран при загрузке игры."/>

			<CheckBox x:Name="chkAutoSubscribe" x:FieldModifier="public"
                      Canvas.Left="547" Canvas.Top="127"
                      Style="{DynamicResource RealmCheckBoxStyle}"
                      IsChecked="True"
                      Content="Авто-подписка на моды Workshop"
                      ToolTip="Пытается автоматически подписать на моды через Steam; при необходимости открывает страницы модов в Workshop." HorizontalAlignment="Left" VerticalAlignment="Center"/>
		</Canvas>
	</Grid>
</UserControl>
